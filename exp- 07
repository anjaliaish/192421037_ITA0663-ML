import pandas as pd
from sklearn.linear_model import LogisticRegression

data = {
    'Hours': [1, 2, 3, 4, 5, 6, 7, 8],
    'Pass':  [0, 0, 0, 0, 1, 1, 1, 1]
}

df = pd.DataFrame(data)
X = df[['Hours']]
y = df['Pass']

model = LogisticRegression()
model.fit(X, y)

prediction = model.predict([[5.5]])

print("Prediction:", prediction[0])

if prediction[0] == 1:
    print("Result: Pass")
else:
    print("Result: Fail")
